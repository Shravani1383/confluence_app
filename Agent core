async def run_confluence_agent(query: str):
    context = {
        "query": query,
        "history": []
    }

    visited_urls = set()

    MAX_STEPS = 8
    MAX_FETCHES = 5

    for step in range(MAX_STEPS):

        planner_input = {
            "query": context["query"],
            "history": context["history"]
        }

        plan = await planner.run(task=json.dumps(planner_input))
        plan_json = json.loads(plan.messages[-1].content)

        action = plan_json["action"]
        action_input = plan_json["input"]

        print(f"\n[Step {step}] → {action}: {action_input}")

        # ---------------- SEARCH ----------------
        if action == "search":
            result = confluence_search_pages(action_input)

            context["history"].append({
                "action": "search",
                "input": action_input,
                "result": result
            })

        # ---------------- FETCH ----------------
        elif action == "fetch":
            if action_input in visited_urls:
                continue

            visited_urls.add(action_input)

            page = confluence_fetch_page(action_input)

            extracted_urls = extract_urls(page.get("content", ""))

            context["history"].append({
                "action": "fetch",
                "input": action_input,
                "result": page,
                "extracted_urls": extracted_urls
            })

        # ---------------- FETCH LINKS ----------------
        elif action == "fetch_links":
            try:
                urls = json.loads(action_input)
            except:
                urls = []

            fetched_pages = []

            for url in urls:
                if url not in visited_urls and len(visited_urls) < MAX_FETCHES:
                    visited_urls.add(url)
                    page = confluence_fetch_page(url)
                    fetched_pages.append(page)

            context["history"].append({
                "action": "fetch_links",
                "input": urls,
                "result": fetched_pages
            })

        # ---------------- FINAL ----------------
        elif action == "final":
            final_input = {
                "query": context["query"],
                "history": context["history"]
            }

            final = await synthesizer.run(task=json.dumps(final_input))
            return json.loads(final.messages[-1].content)

        else:
            raise ValueError(f"Unknown action: {action}")

    return {
        "status": "error",
        "answer": "Max steps reached",
        "sources": [],
        "errors": ["loop exceeded"]
    }


