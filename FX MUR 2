(function extractLayout() {
  const vw = window.innerWidth;
  const vh = window.innerHeight;

  function getRole(el) {
    const tag = el.tagName.toLowerCase();
    const cls = el.className?.toString().toLowerCase() || '';
    const id = el.id?.toLowerCase() || '';
    const role = el.getAttribute('role') || '';
    const hint = [tag, cls, id, role].join(' ');
    if (/nav|navbar|navigation|menu|header/.test(hint)) return 'navigation';
    if (/hero|banner|jumbotron/.test(hint)) return 'hero';
    if (/footer/.test(hint)) return 'footer';
    if (/sidebar|aside/.test(hint)) return 'sidebar';
    if (/card|tile|item|product/.test(hint)) return 'card';
    if (/grid|row|columns|flex/.test(hint)) return 'grid-container';
    if (/section|wrapper|container|content/.test(hint)) return 'section';
    if (/modal|dialog|overlay/.test(hint)) return 'modal';
    if (tag === 'header') return 'header';
    if (tag === 'footer') return 'footer';
    if (tag === 'main') return 'main';
    if (tag === 'aside') return 'sidebar';
    if (tag === 'section') return 'section';
    if (tag === 'nav') return 'navigation';
    return tag;
  }

  function getDisplayInfo(el) {
    const s = getComputedStyle(el);
    return {
      display: s.display,
      flexDirection: s.flexDirection !== 'row' ? s.flexDirection : undefined,
      gridTemplateColumns: s.gridTemplateColumns !== 'none' ? s.gridTemplateColumns : undefined,
      gridTemplateRows: s.gridTemplateRows !== 'none' ? s.gridTemplateRows : undefined,
      gap: s.gap !== 'normal' ? s.gap : undefined,
      justifyContent: s.justifyContent !== 'normal' ? s.justifyContent : undefined,
      alignItems: s.alignItems !== 'normal' ? s.alignItems : undefined,
      position: s.position !== 'static' ? s.position : undefined,
      zIndex: s.zIndex !== 'auto' ? s.zIndex : undefined,
    };
  }

  function isVisible(el) {
    const r = el.getBoundingClientRect();
    const s = getComputedStyle(el);
    return r.width > 0 && r.height > 0 && s.display !== 'none' && s.visibility !== 'hidden' && s.opacity !== '0';
  }

  function isLayoutNode(el) {
    const s = getComputedStyle(el);
    const r = el.getBoundingClientRect();
    const isBlock = ['block','flex','grid','inline-flex','inline-grid'].includes(s.display);
    const isBig = r.width > 80 && r.height > 30;
    return isBlock && isBig && isVisible(el);
  }

  function describeChildren(el, depth = 0, maxDepth = 4) {
    if (depth > maxDepth) return [];
    return Array.from(el.children)
      .filter(isLayoutNode)
      .map(child => {
        const r = child.getBoundingClientRect();
        const s = getComputedStyle(child);
        const node = {
          role: getRole(child),
          tag: child.tagName.toLowerCase(),
          id: child.id || undefined,
          classes: child.className?.toString().trim().split(/\s+/).slice(0, 5).join(' ') || undefined,
          layout: getDisplayInfo(child),
          rect: {
            x: Math.round(r.left),
            y: Math.round(r.top + window.scrollY),
            w: Math.round(r.width),
            h: Math.round(r.height),
          },
          percentWidth: Math.round((r.width / vw) * 100) + '%',
          text: child.innerText?.trim().slice(0, 80) || undefined,
          children: describeChildren(child, depth + 1, maxDepth),
        };
        // Count grid/flex children for column hints
        if (['flex','grid','inline-flex','inline-grid'].includes(s.display)) {
          const visibleKids = Array.from(child.children).filter(isLayoutNode);
          node.childCount = visibleKids.length;
          if (s.display === 'grid' && s.gridTemplateColumns !== 'none') {
            node.columnCount = s.gridTemplateColumns.trim().split(/\s+/).length;
          }
          if (s.display === 'flex' && s.flexDirection !== 'column') {
            node.columnCount = visibleKids.length;
          }
        }
        return node;
      });
  }

  // Top-level sections (above and below fold)
  const topLevelSections = Array.from(document.body.children)
    .filter(isLayoutNode)
    .map(el => {
      const r = el.getBoundingClientRect();
      return {
        role: getRole(el),
        tag: el.tagName.toLowerCase(),
        id: el.id || undefined,
        classes: el.className?.toString().trim().split(/\s+/).slice(0, 5).join(' ') || undefined,
        rect: {
          x: Math.round(r.left),
          y: Math.round(r.top + window.scrollY),
          w: Math.round(r.width),
          h: Math.round(r.height),
        },
        percentWidth: Math.round((r.width / vw) * 100) + '%',
        aboveFold: r.top < vh,
        layout: getDisplayInfo(el),
        children: describeChildren(el, 0, 3),
      };
    });

  // Page-level summary
  const totalHeight = Math.max(document.body.scrollHeight, document.documentElement.scrollHeight);
  const summary = {
    viewport: { width: vw, height: vh },
    totalPageHeight: totalHeight,
    sectionCount: topLevelSections.length,
    hasSticky: topLevelSections.some(s => s.layout.position === 'sticky' || s.layout.position === 'fixed'),
    sections: topLevelSections,
  };

  console.log('=== LAYOUT JSON ===');
  console.log(JSON.stringify(summary, null, 2));
  copy(JSON.stringify(summary, null, 2));
  return summary;
})();
