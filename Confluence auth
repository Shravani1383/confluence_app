🟢 STEP 1: Frontend calls session check

async function checkConfluenceSession() {
  const res = await fetch("/api/confluence/session-check", {
    method: "GET",
    credentials: "include"
  });

  return res.status === 200;
}


---

🟢 STEP 2: Backend verifies session

@app.get("/api/confluence/session-check")
def session_check(request: Request):
    cookie = request.headers.get("cookie")

    if not cookie:
        raise HTTPException(status_code=401)

    response = requests.get(
        f"{CONFLUENCE_BASE}/rest/api/user/current",
        headers={"Cookie": cookie},
        timeout=3
    )

    data = response.json()

    if data.get("type") == "anonymous":
        raise HTTPException(status_code=401)

    return {"status": "active"}


