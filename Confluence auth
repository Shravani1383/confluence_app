🧠 5. Final Frontend Logic (Production Pattern)

async function ensureConfluenceSession() {
  const isActive = await checkConfluenceSession();

  if (isActive) return true;

  // 🔁 Try silent login
  await triggerSilentSSO();

  // 🔁 Retry
  const retry = await checkConfluenceSession();

  if (!retry) {
    // fallback: show message
    alert("Please log into Confluence");
    return false;
  }

  return true;
}


---

Silent SSO Trigger:

function triggerSilentSSO() {
  return new Promise((resolve) => {
    const iframe = document.createElement("iframe");
    iframe.style.display = "none";
    iframe.src = "https://your-confluence-url";

    iframe.onload = () => {
      setTimeout(resolve, 1000); // give time for cookie
    };

    document.body.appendChild(iframe);
  });
}


