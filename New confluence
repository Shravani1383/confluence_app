async def generate_answer(query: str, chunks: List[Dict]) -> str:
    model_client = create_azure_openai_chat_client()

    context = "\n\n".join([
        f"[SOURCE: {c['url']}]\n{c['text']}"
        for c in chunks
    ])

    prompt = f"""
You are a Confluence assistant.

Answer the question using ONLY the provided context.

STRICT RULES:
- Always cite sources using [SOURCE: url]
- If multiple sources support a point, cite all
- Do NOT hallucinate
- If unsure, say "Not found in provided sources"

Question:
{query}

Context:
{context}
"""

    response = await model_client.create(
        messages=[{"role": "user", "content": prompt}]
    )

    return response.content if hasattr(response, "content") else str(response)


