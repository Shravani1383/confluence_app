🔹 Rank Search Results (Embedding-Based)

async def rank_results(query: str, results: List[Dict[str, Any]]) -> List[Dict]:
    texts = [
        f"{r.get('title', '')} {r.get('snippet', '')}"
        for r in results
    ]

    query_emb = (await embed_texts([query]))[0]
    doc_embs = await embed_texts(texts)

    scored = []
    for r, emb in zip(results, doc_embs):
        score = cosine_similarity(query_emb, emb)
        scored.append({**r, "score": score})

    return sorted(scored, key=lambda x: x["score"], reverse=True)


