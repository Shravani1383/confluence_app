🔹 Chunk-Level Ranking (CRITICAL)

async def select_relevant_chunks(query: str, pages: List[Dict]) -> List[Dict]:
    query_emb = (await embed_texts([query]))[0]

    all_chunks = []
    chunk_meta = []

    for p in pages:
        for chunk in p["chunks"]:
            all_chunks.append(chunk)
            chunk_meta.append({
                "url": p["url"],
                "text": chunk
            })

    chunk_embs = await embed_texts(all_chunks)

    scored_chunks = []
    for meta, emb in zip(chunk_meta, chunk_embs):
        score = cosine_similarity(query_emb, emb)
        scored_chunks.append({
            "url": meta["url"],
            "text": meta["text"],
            "score": score
        })

    # Top relevant chunks
    return sorted(scored_chunks, key=lambda x: x["score"], reverse=True)[:8]


