def fetch_pages_sync(urls: List[str]) -> List[Dict]:
    pages = []

    for url in urls:
        try:
            content = confluence_fetch_page(url)  # SYNC ONLY

            if not content:
                continue

            chunks = chunk_text(content)

            pages.append({
                "url": url,
                "chunks": chunks
            })

        except Exception as e:
            print(f"[WARN] Failed {url}: {e}")

    return pages


