            pages.extend(fetch_pages_sync(extra_urls))

        # ---- CASE A: Query only ----
        else:
            search_results = await confluence_search_pages(query, limit=30)

            if not search_results:
                return "No relevant Confluence pages found."

            ranked = await rank_results(query, search_results)
            top_urls = [r["url"] for r in ranked[:3]]

            pages = fetch_pages_sync(top_urls)

        if not pages:
            return "No content retrieved."

        # ---- Chunk-level semantic selection ----
        top_chunks = await select_relevant_chunks(query, pages)

        # ---- Final answer with citations ----
        return await generate_answer(query, top_chunks)

    except Exception as e:
        return f"Error: {str(e)}"


