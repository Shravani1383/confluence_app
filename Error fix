"""
Confluence Agent System - Production Ready
==========================================
Architecture:
  - PlannerAgent  : Detects intent (URL-direct vs keyword-search), orchestrates pipeline
  - SearchAgent   : Searches Confluence, returns top-30 URLs with metadata
  - FetchAgent    : Ranks URLs by relevance, fetches best match(es), returns content
  - AnswerAgent   : Synthesises fetched content into a final user-facing answer

Flow A (keyword query):
  User Query → Planner → SearchAgent (top-30) → FetchAgent (rank + fetch) → AnswerAgent → Response

Flow B (direct URL):
  User Query (contains URL) → Planner → FetchAgent (fetch directly) → AnswerAgent → Response
"""

from __future__ import annotations

import logging
import re
import time
from dataclasses import dataclass, field
from enum import Enum
from typing import Any, Optional, Sequence

import inspect

from autogen_agentchat.agents import AssistantAgent
from autogen_agentchat.messages import TextMessage
from autogen_agentchat.teams import RoundRobinGroupChat
from autogen_core import CancellationToken
from autogen_core.tools import FunctionTool

# ---------------------------------------------------------------------------
# Version-safe AssistantAgent factory
# ---------------------------------------------------------------------------
_AGENT_SUPPORTS_MAX_TOOL_ITER = "max_tool_iterations" in inspect.signature(AssistantAgent.__init__).parameters


def _make_agent(**kwargs: Any) -> AssistantAgent:
    """
    Create an AssistantAgent, stripping `max_tool_iterations` when the
    installed version of autogen-agentchat does not support it yet.
    Upgrade to autogen-agentchat>=0.4.9 to enable the parameter.
    """
    if not _AGENT_SUPPORTS_MAX_TOOL_ITER:
        removed = kwargs.pop("max_tool_iterations", None)
        if removed is not None:
            logger.debug(
                "autogen-agentchat does not support max_tool_iterations — "
                "upgrade to >=0.4.9. Ignoring value=%s for agent '%s'.",
                removed,
                kwargs.get("name", "?"),
            )
    return AssistantAgent(**kwargs)

from chat.agents.confluence.tools.confluence_fetch import confluence_fetch_page
from chat.agents.confluence.tools.confluence_search import confluence_search_pages
from chat.agents.confluence.integrations.llm_client import create_azure_openai_chat_client
from chat.agents.confluence.prompts.system_prompt import SYSTEM_MESSAGE

# ---------------------------------------------------------------------------
# Logging
# ---------------------------------------------------------------------------
logger = logging.getLogger(__name__)

# ---------------------------------------------------------------------------
# Constants
# ---------------------------------------------------------------------------
SEARCH_TOP_K = 30          # how many URLs SearchAgent retrieves
FETCH_TOP_K = 3            # how many of those FetchAgent will actually fetch
MAX_TOOL_ITERATIONS = 10   # guard against infinite loops
AGENT_TIMEOUT_SECONDS = 120

# URL pattern used by the Planner to detect direct-URL queries
_URL_RE = re.compile(r"https?://[^\s\"'<>]+", re.IGNORECASE)


# ---------------------------------------------------------------------------
# Domain types
# ---------------------------------------------------------------------------
class QueryIntent(str, Enum):
    DIRECT_URL = "direct_url"
    KEYWORD_SEARCH = "keyword_search"


@dataclass
class PipelineContext:
    """Shared state threaded through the pipeline."""
    raw_query: str
    intent: QueryIntent = QueryIntent.KEYWORD_SEARCH
    direct_urls: list[str] = field(default_factory=list)
    search_results: list[dict[str, Any]] = field(default_factory=list)  # [{url, title, score}]
    fetched_pages: list[dict[str, Any]] = field(default_factory=list)   # [{url, content}]
    final_answer: str = ""
    error: Optional[str] = None
    latency_ms: dict[str, float] = field(default_factory=dict)


# ---------------------------------------------------------------------------
# Intent detection (runs before any agent)
# ---------------------------------------------------------------------------
def detect_intent(query: str) -> tuple[QueryIntent, list[str]]:
    """Cheaply detect whether the user supplied a URL or a keyword query."""
    urls = _URL_RE.findall(query)
    if urls:
        return QueryIntent.DIRECT_URL, urls
    return QueryIntent.KEYWORD_SEARCH, []


# ---------------------------------------------------------------------------
# Tool wrappers with richer return types
# ---------------------------------------------------------------------------
async def search_confluence_top30(query: str) -> list[dict[str, Any]]:
    """
    Search Confluence and return the top-30 results as a list of dicts.
    Each dict has keys: url, title, space, excerpt, relevance_score.
    """
    logger.info("SearchAgent: querying Confluence for '%s'", query)
    raw = await confluence_search_pages(query, limit=SEARCH_TOP_K)

    # Normalise whatever confluence_search_pages returns into our schema.
    # Adapt this block if the upstream function returns a different shape.
    results: list[dict[str, Any]] = []
    for idx, item in enumerate(raw if isinstance(raw, list) else []):
        if isinstance(item, dict):
            results.append({
                "url": item.get("url") or item.get("_links", {}).get("webui", ""),
                "title": item.get("title", f"Result {idx + 1}"),
                "space": item.get("space", {}).get("name", "") if isinstance(item.get("space"), dict) else "",
                "excerpt": item.get("excerpt", ""),
                "relevance_score": round(1.0 - idx * (1.0 / SEARCH_TOP_K), 3),
            })

    logger.info("SearchAgent: found %d results", len(results))
    return results


async def fetch_confluence_page(url: str) -> dict[str, Any]:
    """
    Fetch a single Confluence page by URL.
    Returns a dict with keys: url, title, content, fetched_at.
    """
    logger.info("FetchAgent: fetching %s", url)
    try:
        raw = await confluence_fetch_page(url)
        if isinstance(raw, dict):
            return {
                "url": url,
                "title": raw.get("title", ""),
                "content": raw.get("body", {}).get("storage", {}).get("value", "")
                           or raw.get("content", "")
                           or str(raw),
                "fetched_at": time.time(),
            }
        return {"url": url, "title": "", "content": str(raw), "fetched_at": time.time()}
    except Exception as exc:
        logger.error("FetchAgent: failed to fetch %s — %s", url, exc)
        return {"url": url, "title": "", "content": "", "fetched_at": time.time(), "error": str(exc)}


# ---------------------------------------------------------------------------
# Agent factory helpers
# ---------------------------------------------------------------------------
def _make_model_client(**kwargs: Any):
    return create_azure_openai_chat_client(parallel_tool_calls=False, **kwargs)


def create_search_agent() -> AssistantAgent:
    """
    SearchAgent is responsible for calling confluence_search_pages and returning
    a ranked list of up to SEARCH_TOP_K URLs with metadata.
    """
    tools = [
        FunctionTool(
            search_confluence_top30,
            name="search_confluence_top30",
            description=(
                f"Search Confluence with a keyword query and return the top {SEARCH_TOP_K} "
                "matching pages as a JSON list. Each item has: url, title, space, excerpt, "
                "relevance_score. Call this ONCE with the user's refined search terms."
            ),
        )
    ]

    system_message = (
        "You are the Confluence Search Agent. Your ONLY job is:\n"
        "1. Extract the best search keywords from the user's query.\n"
        "2. Call `search_confluence_top30` exactly ONCE with those keywords.\n"
        "3. Return the raw JSON list of results — do NOT summarise or filter.\n\n"
        "Rules:\n"
        "- Never fabricate URLs. Only return what the tool returns.\n"
        "- If the tool returns 0 results, say so clearly.\n"
        "- Output format: valid JSON array of result objects.\n"
        "- Do NOT answer the user's question — that is the Answer Agent's job."
    )

    return _make_agent(
        name="search_agent",
        system_message=system_message,
        model_client=_make_model_client(),
        tools=tools,
        model_client_stream=False,
        reflect_on_tool_use=True,
    )


def create_fetch_agent() -> AssistantAgent:
    """
    FetchAgent receives either:
      (a) A JSON list of search results → ranks them, fetches top FETCH_TOP_K
      (b) One or more explicit URLs → fetches each directly
    """
    tools = [
        FunctionTool(
            fetch_confluence_page,
            name="fetch_confluence_page",
            description=(
                "Fetch the full content of a single Confluence page by its URL. "
                "Returns a dict with url, title, content. "
                f"Call this up to {FETCH_TOP_K} times — once per URL you decide to fetch."
            ),
        )
    ]

    system_message = (
        "You are the Confluence Fetch Agent. You receive either:\n"
        "  A) A JSON list of search results (each with url, title, excerpt, relevance_score)\n"
        "  B) One or more explicit Confluence URLs from the user\n\n"
        "Your job:\n"
        f"  Case A: Analyse the results and select the {FETCH_TOP_K} most relevant URLs "
        "based on title, excerpt and relevance_score relative to the original user question. "
        f"Call `fetch_confluence_page` for each selected URL (max {FETCH_TOP_K} calls).\n"
        "  Case B: Call `fetch_confluence_page` for every URL the user provided.\n\n"
        "Rules:\n"
        "- Prefer pages whose title/excerpt directly address the question.\n"
        "- Return ALL fetched page content as a JSON array — do NOT summarise yet.\n"
        "- If a fetch fails (error key present), skip that page and try the next best.\n"
        "- Do NOT answer the user's question — that is the Answer Agent's job."
    )

    return _make_agent(
        name="fetch_agent",
        system_message=system_message,
        model_client=_make_model_client(),
        tools=tools,
        model_client_stream=False,
        reflect_on_tool_use=True,
    )


def create_answer_agent() -> AssistantAgent:
    """
    AnswerAgent receives fetched page content and the original query,
    then produces a clear, cited final answer.
    """
    system_message = (
        "You are the Confluence Answer Agent. You receive:\n"
        "  - The user's original question\n"
        "  - A JSON array of fetched Confluence pages (url, title, content)\n\n"
        "Your job:\n"
        "1. Read the page content carefully.\n"
        "2. Answer the user's question clearly and concisely.\n"
        "3. Cite the source page title and URL for every piece of information.\n"
        "4. If no relevant content was found, say so honestly.\n\n"
        "Format guidelines:\n"
        "- Use markdown for structure (headings, bullets, code blocks).\n"
        "- Put citations inline like: [Page Title](url).\n"
        "- Keep the answer focused — do not dump raw page content.\n"
        "- If multiple pages contribute, synthesise them coherently."
    )

    return _make_agent(
        name="answer_agent",
        system_message=system_message,
        model_client=_make_model_client(),
        tools=[],
        model_client_stream=True,
        reflect_on_tool_use=False,
    )


def create_planner_agent() -> AssistantAgent:
    """
    PlannerAgent is the entry point. It:
      - Detects intent (URL vs keyword)
      - Routes to SearchAgent or directly to FetchAgent
      - Passes context between agents via structured messages
    """
    system_message = (
        "You are the Confluence Planner Agent — the orchestrator of a multi-agent pipeline.\n\n"
        "== PIPELINE RULES ==\n\n"
        "Step 1 — Intent detection (you do this yourself, no tool needed):\n"
        "  - If the user's message contains one or more https:// URLs → DIRECT_URL intent\n"
        "  - Otherwise → KEYWORD_SEARCH intent\n\n"
        "Step 2 — Routing:\n"
        "  KEYWORD_SEARCH:\n"
        "    a. Ask search_agent to search for the user's query.\n"
        "    b. Pass search_agent's result list to fetch_agent.\n"
        "    c. Pass fetch_agent's fetched pages + original query to answer_agent.\n\n"
        "  DIRECT_URL:\n"
        "    a. Pass the URL(s) directly to fetch_agent (skip search_agent).\n"
        "    b. Pass fetch_agent's fetched pages + original query to answer_agent.\n\n"
        "== MESSAGE FORMAT ==\n"
        "When handing off to another agent, prefix your message with:\n"
        "  [TO: search_agent]  or  [TO: fetch_agent]  or  [TO: answer_agent]\n"
        "and include all context that agent needs.\n\n"
        "== RULES ==\n"
        "- Never skip the fetch step.\n"
        "- Never answer the user yourself — always delegate to answer_agent.\n"
        "- If any step fails, report the error clearly to the user.\n"
        "- Maintain a brief internal scratchpad of what each step returned.\n"
        + SYSTEM_MESSAGE
    )

    return _make_agent(
        name="planner_agent",
        system_message=system_message,
        model_client=_make_model_client(),
        tools=[],
        model_client_stream=False,
        reflect_on_tool_use=False,
    )


# ---------------------------------------------------------------------------
# High-level pipeline runner
# ---------------------------------------------------------------------------
class ConfluencePipeline:
    """
    Wires the four agents together and exposes a single `run(query)` coroutine.

    Usage:
        pipeline = ConfluencePipeline()
        result = await pipeline.run("How do I set up SSO in our org?")
        print(result.final_answer)
    """

    def __init__(self) -> None:
        self._planner = create_planner_agent()
        self._search = create_search_agent()
        self._fetch = create_fetch_agent()
        self._answer = create_answer_agent()

        # RoundRobinGroupChat keeps agents in a fixed turn order.
        # The planner's routing instructions drive which agent acts meaningfully
        # each turn; others act as pass-throughs when not addressed.
        self._team = RoundRobinGroupChat(
            participants=[self._planner, self._search, self._fetch, self._answer],
            max_turns=20,  # planner + search(tool loop) + fetch(×3 tool loop) + answer + buffer
        )

    async def run(
        self,
        query: str,
        cancellation_token: Optional[CancellationToken] = None,
    ) -> PipelineContext:
        ctx = PipelineContext(raw_query=query)
        intent, urls = detect_intent(query)
        ctx.intent = intent
        ctx.direct_urls = urls

        t0 = time.perf_counter()
        logger.info("Pipeline START | intent=%s | query=%r", intent.value, query[:120])

        try:
            # Build the initial message to kick off the pipeline
            if intent == QueryIntent.DIRECT_URL:
                kickoff = (
                    f"User query: {query}\n\n"
                    f"Intent detected: DIRECT_URL\n"
                    f"URLs to fetch: {urls}\n\n"
                    "Please orchestrate the pipeline: fetch these URLs and answer the query."
                )
            else:
                kickoff = (
                    f"User query: {query}\n\n"
                    "Intent detected: KEYWORD_SEARCH\n\n"
                    "Please orchestrate the pipeline: search Confluence, fetch the most "
                    "relevant pages, and answer the query."
                )

            result = await self._team.run(
                task=kickoff,
                cancellation_token=cancellation_token or CancellationToken(),
            )

            # Extract the last substantive text message as the final answer
            for msg in reversed(result.messages):
                if isinstance(msg, TextMessage) and msg.source == "answer_agent":
                    ctx.final_answer = msg.content
                    break
            else:
                # Fallback: last message from any agent
                for msg in reversed(result.messages):
                    if isinstance(msg, TextMessage) and msg.content.strip():
                        ctx.final_answer = msg.content
                        break

        except Exception as exc:
            logger.exception("Pipeline ERROR: %s", exc)
            ctx.error = str(exc)
            ctx.final_answer = f"An error occurred while processing your query: {exc}"

        finally:
            elapsed = (time.perf_counter() - t0) * 1000
            ctx.latency_ms["total"] = round(elapsed, 1)
            logger.info(
                "Pipeline END | intent=%s | answer_len=%d | latency=%.0fms | error=%s",
                ctx.intent.value,
                len(ctx.final_answer),
                elapsed,
                ctx.error,
            )

        return ctx


# ---------------------------------------------------------------------------
# Convenience factory (mirrors original create_confluence_agent signature)
# ---------------------------------------------------------------------------
def create_confluence_agent() -> ConfluencePipeline:
    """
    Drop-in replacement factory.
    Returns a ConfluencePipeline instance.

    Example:
        agent = create_confluence_agent()
        ctx   = await agent.run("How do I configure LDAP?")
        print(ctx.final_answer)
    """
    return ConfluencePipeline()
