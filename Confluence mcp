🌐 6. Confluence Client (Secure)

app/confluence_client.py

import requests
from requests.auth import HTTPBasicAuth
from app.config import settings

auth = HTTPBasicAuth(
    settings.CONFLUENCE_EMAIL,
    settings.CONFLUENCE_PAT
)

def confluence_get(endpoint, params=None):
    url = f"{settings.CONFLUENCE_BASE_URL}{endpoint}"

    response = requests.get(
        url,
        auth=auth,
        params=params,
        timeout=10
    )

    response.raise_for_status()
    return response.json()


