📄 8. Fetch Tool

app/tools/fetch.py

from app.confluence_client import confluence_get

def fetch_confluence_page(pageId: str):
    if not pageId:
        raise ValueError("pageId is required")

    data = confluence_get(
        f"/rest/api/content/{pageId}",
        params={"expand": "body.storage"}
    )

    return {
        "title": data["title"],
        "content": data["body"]["storage"]["value"]
    }


