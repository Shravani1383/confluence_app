🧠 9. FastMCP Server (WITH AUTH WRAPPER)

app/main.py

from fastmcp import FastMCP
from fastapi import Request
from app.auth import verify_internal_request
from app.tools.search import search_confluence
from app.tools.fetch import fetch_confluence_page

mcp = FastMCP("confluence-mcp")

# 🔐 Wrap tools with auth
def secure_tool(func):
    async def wrapper(*args, request: Request = None, **kwargs):
        verify_internal_request(request)
        return func(*args, **kwargs)
    return wrapper


@mcp.tool()
@secure_tool
def search_confluence_tool(query: str):
    """Search Confluence pages"""
    return search_confluence(query)


@mcp.tool()
@secure_tool
def fetch_confluence_page_tool(pageId: str):
    """Fetch Confluence page content"""
    return fetch_confluence_page(pageId)


if __name__ == "__main__":
    mcp.run(host="0.0.0.0", port=3000)


