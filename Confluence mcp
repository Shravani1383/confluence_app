🔎 7. Search Tool

app/tools/search.py

from app.confluence_client import confluence_get

def search_confluence(query: str):
    if not query:
        raise ValueError("Query is required")

    data = confluence_get(
        "/rest/api/search",
        params={
            "cql": f'type=page AND text ~ "{query}"',
            "limit": 5
        }
    )

    return [
        {
            "id": r["content"]["id"],
            "title": r["content"]["title"],
            "url": r["url"]
        }
        for r in data.get("results", [])
    ]


