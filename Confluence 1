✅ 7. Public service entrypoint (THIS replaces GraphAgent)

async def run_confluence(messages: List[Dict[str, Any]], llm_client) -> str:
    try:
        task = build_chat_task(messages)
        result = await run_confluence_agent(llm_client, task)
        return result or "No response generated."

    except Exception as e:
        logger.exception("Confluence agent failed")
        return f"Error: {str(e)}"


