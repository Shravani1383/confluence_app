✅ 2. Tool implementations (with HARD constraints)

async def confluence_search_tool(query: str):
    results = await confluence_search_pages(query)

    # Normalize + trim for LLM
    formatted = []
    for r in (results or [])[:30]:
        formatted.append({
            "url": r.get("url"),
            "title": r.get("title"),
            "snippet": (r.get("snippet") or "")[:300]
        })

    return formatted


async def confluence_fetch_tool(urls: List[str]):
    urls = urls[:MAX_FETCH_URLS]  # 🔒 enforce max 3

    docs = []
    for url in urls:
        try:
            content = await confluence_fetch_page(url)
            docs.append({
                "url": url,
                "content": (content or "")[:5000]  # prevent huge payloads
            })
        except Exception as e:
            docs.append({"url": url, "error": str(e)})

    return docs


