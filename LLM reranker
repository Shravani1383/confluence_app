from chat.agents.confluence.llm_reranker import rerank_with_llm
from chat.agents.confluence.confluence_agents import get_confluence_agent


async def confluence_search_pages(query: str) -> list:
    raw_pages = await _search_confluence_api(query)

    docs = []
    for p in raw_pages:
        docs.append({
            "title": p.get("title", ""),
            "content": p.get("excerpt", "") or "",
            "url": p.get("url")
        })

    # Limit candidates (important for cost)
    candidate_docs = docs[:10]

    # 🔥 Get agent client (reuse existing)
    agent = get_confluence_agent()
    client = agent.model_client

    # 🔥 LLM reranking
    ranked_docs = await rerank_with_llm(
        query=query,
        docs=candidate_docs,
        client=client,
        top_k=3
    )

    return ranked_docs


