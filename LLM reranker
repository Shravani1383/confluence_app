# chat/agents/confluence/llm_reranker.py

import json
from typing import List, Dict


async def rerank_with_llm(
    query: str,
    docs: List[Dict],
    client,
    top_k: int = 3
) -> List[Dict]:
    """
    docs = [{"title": ..., "content": ..., "url": ...}]
    """

    if not docs:
        return []

    # Limit content to avoid token explosion
    formatted_docs = []
    for i, d in enumerate(docs):
        formatted_docs.append(
            f"{i+1}. Title: {d.get('title','')}\n"
            f"Content: {d.get('content','')[:300]}\n"
            f"URL: {d.get('url','')}"
        )

    docs_block = "\n\n".join(formatted_docs)

    prompt = f"""
You are a relevance ranking system.

Query:
"{query}"

Documents:
{docs_block}

Task:
Select the top {top_k} most relevant documents that best answer the query.

Return ONLY JSON in this format:
{{
  "ranking": [doc_number1, doc_number2, doc_number3]
}}

Rules:
- Use document numbers (1-based index)
- No explanation
- Only JSON output
"""

    response = await client.create(   # adjust if your client uses different method
        messages=[{"role": "user", "content": prompt}],
        temperature=0
    )

    content = response.messages[-1].content.strip()

    try:
        parsed = json.loads(content)
        indices = parsed.get("ranking", [])
    except Exception:
        # fallback: return first k docs
        return docs[:top_k]

    # Convert indices → docs
    ranked_docs = []
    for idx in indices:
        if 1 <= idx <= len(docs):
            ranked_docs.append(docs[idx - 1])

    # fallback safety
    if not ranked_docs:
        return docs[:top_k]

    return ranked_docs[:top_k]


