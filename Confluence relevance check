# chat/agents/confluence/relevance.py

import math
import re
from typing import List, Dict


def _tokenize(text: str) -> List[str]:
    return re.findall(r"\w+", text.lower())


def _term_frequency(tokens: List[str]) -> Dict[str, int]:
    tf = {}
    for t in tokens:
        tf[t] = tf.get(t, 0) + 1
    return tf


def _compute_idf(docs_tokens: List[List[str]]) -> Dict[str, float]:
    import math

    N = len(docs_tokens)
    df = {}

    for tokens in docs_tokens:
        for token in set(tokens):
            df[token] = df.get(token, 0) + 1

    idf = {}
    for token, freq in df.items():
        idf[token] = math.log((N + 1) / (freq + 1)) + 1

    return idf


def bm25_score(query: str, documents: List[str]) -> List[float]:
    """
    Lightweight BM25-style scoring
    """
    k1 = 1.5
    b = 0.75

    doc_tokens = [_tokenize(doc) for doc in documents]
    query_tokens = _tokenize(query)

    avgdl = sum(len(t) for t in doc_tokens) / (len(doc_tokens) or 1)
    idf = _compute_idf(doc_tokens)

    scores = []

    for tokens in doc_tokens:
        tf = _term_frequency(tokens)
        score = 0.0

        for q in query_tokens:
            if q not in tf:
                continue

            freq = tf[q]
            numerator = freq * (k1 + 1)
            denominator = freq + k1 * (1 - b + b * len(tokens) / avgdl)

            score += idf.get(q, 0) * (numerator / denominator)

        scores.append(score)

    return scores


def simple_semantic_boost(query: str, doc: str) -> float:
    """
    Very lightweight semantic signal:
    boosts if query words appear in title-like positions
    """
    query_tokens = set(_tokenize(query))
    doc_tokens = _tokenize(doc[:200])  # first 200 chars = "title-ish"

    overlap = query_tokens.intersection(doc_tokens)
    return len(overlap) * 0.5


def rank_documents(query: str, docs: List[Dict], top_k: int = 5) -> List[Dict]:
    """
    docs = [{"title": ..., "content": ..., "url": ...}]
    """
    if not docs:
        return []

    texts = [
        f"{d.get('title','')} {d.get('content','')[:500]}"
        for d in docs
    ]

    bm25_scores = bm25_score(query, texts)

    scored_docs = []
    for i, doc in enumerate(docs):
        semantic = simple_semantic_boost(query, texts[i])
        total_score = bm25_scores[i] + semantic

        scored_docs.append({
            **doc,
            "score": total_score
        })

    ranked = sorted(scored_docs, key=lambda x: x["score"], reverse=True)

    return ranked[:top_k]


