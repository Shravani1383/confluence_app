# graph/nodes/router.py
def route_next(state):
    steps = state.get("plan", {}).get("steps", [])

    if not steps:
        return "final"

    next_step = steps[0]["tool"]

    mapping = {
        "confluence_search": "search",
        "rank_results": "rank",
        "confluence_fetch": "fetch",
        "synthesize": "synthesize"
    }

    return mapping.get(next_step, "final")


