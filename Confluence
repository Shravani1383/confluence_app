🧠 Step 5: Rank Node (LLM-powered)

This is 🔥 critical for quality.

# graph/nodes/rank.py
import json

async def rank_node(state, llm):
    results = state["search_results"]

    prompt = f"""
Rank the most relevant Confluence pages for this query:

Query: {state['user_query']}

Results:
{results}

Return top 3 URLs as JSON:
{{ "top_urls": ["url1", "url2", "url3"] }}
"""

    response = await llm.invoke(prompt)

    try:
        data = json.loads(response)
        selected = [
            r for r in results if r["url"] in data["top_urls"]
        ]
        return {**state, "selected_docs": selected}
    except:
        return {
            **state,
            "selected_docs": results[:3]  # fallback
        }


