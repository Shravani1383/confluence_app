# graph/build_graph.py
from langgraph.graph import StateGraph, END

def build_graph(llm):

    graph = StateGraph(AgentState)

    graph.add_node("planner", lambda s: planner_node(s, llm))
    graph.add_node("search", search_node)
    graph.add_node("rank", lambda s: rank_node(s, llm))
    graph.add_node("fetch", fetch_node)
    graph.add_node("synthesize", lambda s: synthesize_node(s, llm))
    graph.add_node("final", final_node)

    graph.set_entry_point("planner")

    # Dynamic routing loop
    graph.add_conditional_edges(
        "planner",
        route_next,
        {
            "search": "search",
            "rank": "rank",
            "fetch": "fetch",
            "synthesize": "synthesize",
            "final": "final",
        }
    )

    # Loop after each step
    for node in ["search", "rank", "fetch", "synthesize"]:
        graph.add_conditional_edges(
            node,
            route_next,
            {
                "search": "search",
                "rank": "rank",
                "fetch": "fetch",
                "synthesize": "synthesize",
                "final": "final",
            }
        )

    graph.add_edge("final", END)

    return graph.compile()


