🧾 Step 7: Synthesis Node (Multi-doc reasoning)

# graph/nodes/synthesize.py
async def synthesize_node(state, llm):
    docs = state["fetched_docs"]

    prompt = f"""
Answer the user's question using the following Confluence pages.

Question:
{state['user_query']}

Documents:
{docs}

Instructions:
- Combine information
- Remove redundancy
- Be concise
- Cite URLs if useful
"""

    response = await llm.invoke(prompt)

    return {
        **state,
        "final_answer": response
    }


