📄 Step 6: Fetch Node (Multi-doc)

# graph/nodes/fetch.py
async def fetch_node(state):
    step = state["plan"]["steps"].pop(0)

    urls = step.get("input") or [doc["url"] for doc in state["selected_docs"]]

    docs = []
    for url in urls:
        try:
            content = await confluence_fetch_page(url)
            docs.append({"url": url, "content": content})
        except Exception as e:
            state["errors"].append(str(e))

    return {
        **state,
        "fetched_docs": docs
    }


