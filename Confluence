🧠 Step 2: LLM Planner (Dynamic Tool Selection)

No more static "search|fetch" — the LLM decides steps.

# graph/nodes/planner.py
import json

async def planner_node(state, llm):
    prompt = f"""
You are an intelligent planner.

User query: {state['user_query']}

Available tools:
- confluence_search(query)
- confluence_fetch(url)

Decide a multi-step plan.

Return JSON:
{{
  "steps": [
    {{ "tool": "confluence_search", "input": "..." }},
    {{ "tool": "rank_results" }},
    {{ "tool": "confluence_fetch", "input": ["url1", "url2"] }},
    {{ "tool": "synthesize" }}
  ]
}}
"""

    response = await llm.invoke(prompt)

    try:
        plan = json.loads(response)
        return {**state, "plan": plan}
    except Exception as e:
        return {
            **state,
            "errors": state["errors"] + [f"Planner error: {str(e)}"]
        }


