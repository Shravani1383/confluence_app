import requests

MCP_URL = "http://localhost:8000/mcp"

def call_tool(name, args):
    response = requests.post(
        MCP_URL,
        json={
            "jsonrpc": "2.0",
            "id": 1,
            "method": "tools/call",
            "params": {
                "name": name,
                "arguments": args
            }
        }
    )
    return response.json()

# Test 1: List tools
print(requests.post(MCP_URL, json={
    "jsonrpc": "2.0",
    "id": 1,
    "method": "tools/list"
}).json())

# Test 2: Raw search
print(call_tool("search_confluence", {"keywords": "onboarding"}))

# Test 3: AutoGen agent
print(call_tool(
    "ask_confluence_agent",
    {
        "session_id": "test-session",
        "message": "Search onboarding docs"
    }
))
